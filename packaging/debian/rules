#!/usr/bin/make -f
# SPDX-License-Identifier: MIT

export DH_VERBOSE = 1
export CGO_ENABLED = 1

# Pass hardening flags through to CGO.
export DEB_BUILD_MAINT_OPTIONS = hardening=+all
DPKG_EXPORT_BUILDFLAGS = 1
include /usr/share/dpkg/buildflags.mk

# Canonical upstream version (without the Debian revision).
VERSION := $(shell dpkg-parsechangelog -S Version | cut -d- -f1)

%:
	dh $@ --buildsystem=golang --with=golang

override_dh_auto_build:
	go build \
		-trimpath \
		-buildmode=pie \
		-ldflags "-linkmode=external -X main.version=v$(VERSION)" \
		-o debian/tidalt/usr/bin/tidalt \
		./cmd/tidalt

override_dh_auto_test:
	go test ./...

override_dh_auto_install:
	# Binary is already placed by dh_auto_build above.
	# Desktop file (for tidal:// URL handler).
	install -Dm644 cmd/tidalt/tidalt.desktop \
		debian/tidalt/usr/share/applications/tidalt.desktop
